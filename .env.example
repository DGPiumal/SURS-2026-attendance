# =================================================================
# SURS 2026 ATTENDANCE APP - ENVIRONMENT VARIABLES TEMPLATE
# Instructions: Copy this file to .env and fill in the actual values.
# DO NOT COMMIT THE ACTUAL .env FILE TO GITHUB.
# =================================================================

# --- Supabase Configuration ---
# Get these from: Supabase Project Settings > API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-public-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-secret-service-role-key-here"

# --- FastAPI Backend Settings ---
API_HOST="0.0.0.0"
API_PORT=8000
DEBUG_MODE=True
# Generate a random string for security: openssl rand -hex 32
SECRET_KEY="your-super-secret-api-key-for-jwt"

# --- Database Tables (For internal reference) ---
# Ensure these tables exist in your Supabase SQL editor
STUDENTS_TABLE="students"
ATTENDANCE_LOG_TABLE="attendance_records"

# --- Streamlit Analytics Settings ---
# Used by the dashboard to pull data
STREAMLIT_SERVER_PORT=8501
STREAMLIT_THEME_BASE="light"

# --- App Metadata ---
SYMPOSIUM_YEAR=2026
ORGANIZATION_NAME="University_of_Peradeniya_Science_Faculty"
